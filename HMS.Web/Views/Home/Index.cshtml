@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<div class="bg-primary text-white py-5 mb-5 rounded-3">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">🏥 Hospital Management System</h1>
        <p class="lead mt-3">Your health is our priority. Book appointments with the best doctors.</p>
        @if (!User.Identity.IsAuthenticated)
        {
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-light btn-lg me-3 mt-3">Login</a>
            <a asp-area="Identity" asp-page="/Account/PatientRegister" class="btn btn-outline-light btn-lg mt-3">Register as Patient</a>
        }
    </div>
</div>

<!-- Features Section -->
<div class="container mb-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-4">
                <h2>🩺</h2>
                <h5 class="fw-bold mt-2">Expert Doctors</h5>
                <p class="text-muted">Find the best specialists for your health needs.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-4">
                <h2>📅</h2>
                <h5 class="fw-bold mt-2">Easy Appointments</h5>
                <p class="text-muted">Book appointments online quickly and easily.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-4">
                <h2>🏨</h2>
                <h5 class="fw-bold mt-2">Modern Facilities</h5>
                <p class="text-muted">State-of-the-art hospital facilities for your care.</p>
            </div>
        </div>
    </div>
</div>

<!-- Role Based Section -->
@if (!User.Identity.IsAuthenticated)
{
    <div class="container mb-5">
        <h3 class="text-center mb-4">Join Us As</h3>
        <div class="row text-center">
            <div class="col-md-6 mb-4">
                <div class="card shadow h-100 p-4 border-primary">
                    <h2>👨‍⚕️</h2>
                    <h5 class="fw-bold mt-2">Doctor</h5>
                    <p class="text-muted">Register as a doctor and manage your schedules.</p>
                    <a asp-area="Identity" asp-page="/Account/DoctorRegister" class="btn btn-primary mt-2">Register as Doctor</a>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card shadow h-100 p-4 border-success">
                    <h2>🧑‍🤝‍🧑</h2>
                    <h5 class="fw-bold mt-2">Patient</h5>
                    <p class="text-muted">Register as a patient and book appointments.</p>
                    <a asp-area="Identity" asp-page="/Account/PatientRegister" class="btn btn-success mt-2">Register as Patient</a>
                </div>
            </div>
        </div>
    </div>
}