@model IEnumerable<DAL.Models.Appoinment>
@{
    ViewData["Title"] = "My Appointments";
}

<h2 class="text-center mb-4">My Appointments</h2>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No appointments found. <a asp-action="Index">Book an appointment</a>
    </div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-primary">
            <tr>
                <th>Appointment No</th>
                <th>Doctor</th>
                <th>Type</th>
                <th>Date</th>
                <th>Description</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Number</td>
                    <td>
                        @(item.Doctor?.name
                          ?? item.Doctor?.UserName
                          ?? item.Doctor?.Email
                          ?? "N/A")
                    </td>
                    <td>@item.Type</td>
                    <td>@item.CreateDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.Description</td>
                    <td>
                        <a asp-action="CancelAppointment" asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure?')">Cancel</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="d-flex gap-2 mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to Doctor List</a>
    <a asp-action="Bills" class="btn btn-primary">View Bills</a>
</div>