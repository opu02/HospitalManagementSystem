@model BLL.Utilities.PagedResult<BLL.ViewModels.TimingViewModel>
@{
    ViewData["Title"] = "My Timings";
}

<h2>My Timings</h2>

<a asp-action="AddTiming" class="btn btn-primary mb-3">Add New Timing</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Date</th>
            <th>Morning Start</th>
            <th>Morning End</th>
            <th>Afternoon Start</th>
            <th>Afternoon End</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Data)
        {
            <tr>
                <td>@item.ScheduleDate.ToString("dd/MM/yyyy")</td>
                <td>@item.MorningShiftStartTime</td>
                <td>@item.MorningShiftEndTime</td>
                <td>@item.AfternoonShiftStartTime</td>
                <td>@item.AfternoonShiftEndTime</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>