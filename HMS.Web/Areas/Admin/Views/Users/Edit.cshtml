@model BLL.ViewModels.ApplicationUserViewModel
@using DAL
@{
    ViewData["Title"] = "Edit User";
}

<h2>Edit User</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-floating mb-3">
        <input asp-for="name" class="form-control" />
        <label asp-for="name">Full Name</label>
        <span asp-validation-for="name" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Email" class="form-control" />
        <label asp-for="Email">Email</label>
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <select asp-for="Gender" asp-items="@Html.GetEnumSelectList<Gender>()" class="form-control">
        </select>
        <label asp-for="Gender">Gender</label>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="City" class="form-control" />
        <label asp-for="City">City</label>
        <span asp-validation-for="City" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Specialist" class="form-control" />
        <label asp-for="Specialist">Specialist</label>
        <span asp-validation-for="Specialist" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <input asp-for="IsDoctor" class="form-check-input" type="checkbox" />
            <label asp-for="IsDoctor" class="form-check-label">Is Doctor</label>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>