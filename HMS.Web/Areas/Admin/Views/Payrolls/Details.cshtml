@model DAL.Models.Payroll
<h2>Payroll Details</h2>
<dl class="row">
    <dt class="col-sm-2">Employee</dt>
    <dd class="col-sm-10">@Model.Employee?.UserName</dd>
    <dt class="col-sm-2">Salary</dt>
    <dd class="col-sm-10">@Model.Salary</dd>
    <dt class="col-sm-2">NetSalary</dt>
    <dd class="col-sm-10">@Model.NetSalary</dd>
    <dt class="col-sm-2">HourlySalary</dt>
    <dd class="col-sm-10">@Model.HourlySalary</dd>
    <dt class="col-sm-2">BonusSalary</dt>
    <dd class="col-sm-10">@Model.BonusSalary</dd>
    <dt class="col-sm-2">Compensation</dt>
    <dd class="col-sm-10">@Model.Compensation</dd>
    <dt class="col-sm-2">AccountNumber</dt>
    <dd class="col-sm-10">@Model.AccountNumber</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>